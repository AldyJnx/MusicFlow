<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_MusicFlow"
                  targetNamespace="http://musicflow.app/bpmn">

  <bpmn:collaboration id="Collaboration_VistaCancion">
    <bpmn:participant id="Participant_MusicFlow" name="MusicFlow - Vista de una Cancion (EQ + Agente IA)" processRef="Process_VistaCancion" />
  </bpmn:collaboration>

  <bpmn:process id="Process_VistaCancion" isExecutable="false">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Usuario" name="Usuario (Cliente)">
        <bpmn:flowNodeRef>StartEvent_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_EQ</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AIRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Accept</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_App" name="Aplicacion MusicFlow (Reproductor / EQ)">
        <bpmn:flowNodeRef>Task_Load</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LoadEQ</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Render</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Play</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Apply</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Sync</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_End</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IA" name="Backend / Agente IA (Claude)">
        <bpmn:flowNodeRef>Task_AIProcess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AISuggest</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Start" name="Abrir vista de cancion">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_Load" name="Cargar track, audio y metadatos">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_LoadEQ" name="Cargar EQ multinivel (Global -&gt; Playlist -&gt; Track -&gt; Segmento)">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Render" name="Mostrar reproductor y bandas de EQ">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Play" name="Reproducir aplicando EQ por segmento">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_EQ" name="Como ajustar el EQ?">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Manual" name="Ajustar EQ manualmente (bandas)">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AIRequest" name="Pedir sugerencia al Agente IA (lenguaje natural)">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AIProcess" name="Procesar prompt con Claude (API IA)">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AISuggest" name="Generar configuracion de EQ sugerida">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Review" name="Revisar sugerencia de EQ">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Accept" name="Aceptar sugerencia?">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_Apply" name="Aplicar nueva configuracion de EQ">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Sync" name="Guardar y sincronizar (offline / nube)">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_End" name="EQ aplicado y guardado">
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Start" targetRef="Task_Load" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_Load" targetRef="Task_LoadEQ" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_LoadEQ" targetRef="Task_Render" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_Render" targetRef="Task_Play" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_Play" targetRef="Gateway_EQ" />
    <bpmn:sequenceFlow id="Flow_06" name="Manual" sourceRef="Gateway_EQ" targetRef="Task_Manual" />
    <bpmn:sequenceFlow id="Flow_07" name="Con IA" sourceRef="Gateway_EQ" targetRef="Task_AIRequest" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_Manual" targetRef="Task_Apply" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_AIRequest" targetRef="Task_AIProcess" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_AIProcess" targetRef="Task_AISuggest" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_AISuggest" targetRef="Task_Review" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Review" targetRef="Gateway_Accept" />
    <bpmn:sequenceFlow id="Flow_13" name="Si" sourceRef="Gateway_Accept" targetRef="Task_Apply" />
    <bpmn:sequenceFlow id="Flow_14" name="No, reintentar" sourceRef="Gateway_Accept" targetRef="Task_AIRequest" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Apply" targetRef="Task_Sync" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_Sync" targetRef="EndEvent_End" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_VistaCancion">

      <bpmndi:BPMNShape id="Participant_MusicFlow_di" bpmnElement="Participant_MusicFlow" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1960" height="680" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Usuario_di" bpmnElement="Lane_Usuario" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1930" height="280" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_App_di" bpmnElement="Lane_App" isHorizontal="true">
        <dc:Bounds x="190" y="360" width="1930" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_IA_di" bpmnElement="Lane_IA" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="1930" height="200" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_Start_di" bpmnElement="StartEvent_Start">
        <dc:Bounds x="244" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="228" y="245" width="70" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_EQ_di" bpmnElement="Gateway_EQ" isMarkerVisible="true">
        <dc:Bounds x="985" y="195" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="965" y="165" width="90" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Manual_di" bpmnElement="Task_Manual">
        <dc:Bounds x="1090" y="120" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AIRequest_di" bpmnElement="Task_AIRequest">
        <dc:Bounds x="1090" y="250" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Review_di" bpmnElement="Task_Review">
        <dc:Bounds x="1290" y="250" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Accept_di" bpmnElement="Gateway_Accept" isMarkerVisible="true">
        <dc:Bounds x="1490" y="260" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1470" y="230" width="90" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_Load_di" bpmnElement="Task_Load">
        <dc:Bounds x="320" y="420" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LoadEQ_di" bpmnElement="Task_LoadEQ">
        <dc:Bounds x="500" y="420" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Render_di" bpmnElement="Task_Render">
        <dc:Bounds x="680" y="420" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Play_di" bpmnElement="Task_Play">
        <dc:Bounds x="850" y="420" width="120" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Apply_di" bpmnElement="Task_Apply">
        <dc:Bounds x="1620" y="420" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Sync_di" bpmnElement="Task_Sync">
        <dc:Bounds x="1820" y="420" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_End_di" bpmnElement="EndEvent_End">
        <dc:Bounds x="2030" y="437" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="2008" y="480" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_AIProcess_di" bpmnElement="Task_AIProcess">
        <dc:Bounds x="1090" y="620" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AISuggest_di" bpmnElement="Task_AISuggest">
        <dc:Bounds x="1290" y="620" width="150" height="70" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="262" y="238" />
        <di:waypoint x="262" y="455" />
        <di:waypoint x="320" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="460" y="455" />
        <di:waypoint x="500" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03">
        <di:waypoint x="640" y="455" />
        <di:waypoint x="680" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="820" y="455" />
        <di:waypoint x="850" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05">
        <di:waypoint x="970" y="455" />
        <di:waypoint x="1010" y="455" />
        <di:waypoint x="1010" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06">
        <di:waypoint x="1010" y="195" />
        <di:waypoint x="1010" y="155" />
        <di:waypoint x="1090" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07">
        <di:waypoint x="1035" y="220" />
        <di:waypoint x="1063" y="220" />
        <di:waypoint x="1063" y="285" />
        <di:waypoint x="1090" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_08_di" bpmnElement="Flow_08">
        <di:waypoint x="1240" y="155" />
        <di:waypoint x="1695" y="155" />
        <di:waypoint x="1695" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_09_di" bpmnElement="Flow_09">
        <di:waypoint x="1165" y="320" />
        <di:waypoint x="1165" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1240" y="655" />
        <di:waypoint x="1290" y="655" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1365" y="620" />
        <di:waypoint x="1365" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1440" y="285" />
        <di:waypoint x="1490" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1515" y="310" />
        <di:waypoint x="1515" y="455" />
        <di:waypoint x="1620" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1515" y="260" />
        <di:waypoint x="1515" y="225" />
        <di:waypoint x="1165" y="225" />
        <di:waypoint x="1165" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1770" y="455" />
        <di:waypoint x="1820" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1970" y="455" />
        <di:waypoint x="2030" y="455" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
