<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_cliente" targetNamespace="http://musicflow.app/bpmn">
  <bpmn:collaboration id="Collab_cliente" name="MusicFlow - Modulo Cliente">
    <bpmn:participant id="Part_Home" name="Inicio" processRef="Proc_Home" />
    <bpmn:participant id="Part_Library" name="Biblioteca" processRef="Proc_Library" />
    <bpmn:participant id="Part_Artist" name="Artista" processRef="Proc_Artist" />
    <bpmn:participant id="Part_Playlists" name="Playlists" processRef="Proc_Playlists" />
    <bpmn:participant id="Part_PlaylistDetail" name="Detalle de playlist" processRef="Proc_PlaylistDetail" />
    <bpmn:participant id="Part_NowPlaying" name="Now Playing" processRef="Proc_NowPlaying" />
    <bpmn:participant id="Part_Equalizer" name="Ecualizador" processRef="Proc_Equalizer" />
    <bpmn:participant id="Part_AiMixer" name="AI Mixer (Agente IA)" processRef="Proc_AiMixer" />
    <bpmn:participant id="Part_Profile" name="Perfil" processRef="Proc_Profile" />
    <bpmn:participant id="Part_Segments" name="Segmentos" processRef="Proc_Segments" />
    <bpmn:participant id="Part_Studio" name="Studio" processRef="Proc_Studio" />
    <bpmn:participant id="Part_Settings" name="Ajustes" processRef="Proc_Settings" />
    <bpmn:participant id="Part_Billing" name="Facturacion" processRef="Proc_Billing" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Home" name="Inicio" isExecutable="false">
    <bpmn:startEvent id="Home_s" name="Abrir Inicio">
      <bpmn:outgoing>Home_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Home_t1" name="Cargar destacados, recientes, mas escuchadas y artistas">
      <bpmn:incoming>Home_f1</bpmn:incoming>
      <bpmn:outgoing>Home_f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Home_g0" name="Hay catalogo?">
      <bpmn:incoming>Home_f2</bpmn:incoming>
      <bpmn:outgoing>Home_f3</bpmn:outgoing>
      <bpmn:outgoing>Home_f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Home_e0" name="Vacio -&gt; importar en Biblioteca">
      <bpmn:incoming>Home_f3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Home_t2" name="Mostrar Inicio (hero + carruseles)">
      <bpmn:incoming>Home_f4</bpmn:incoming>
      <bpmn:incoming>Home_f7</bpmn:incoming>
      <bpmn:outgoing>Home_f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Home_g" name="Accion?">
      <bpmn:incoming>Home_f5</bpmn:incoming>
      <bpmn:outgoing>Home_f6</bpmn:outgoing>
      <bpmn:outgoing>Home_f8</bpmn:outgoing>
      <bpmn:outgoing>Home_f9</bpmn:outgoing>
      <bpmn:outgoing>Home_f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Home_t3" name="Guardar / agregar a cola">
      <bpmn:incoming>Home_f6</bpmn:incoming>
      <bpmn:outgoing>Home_f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Home_e1" name="Ver todo -&gt; Biblioteca">
      <bpmn:incoming>Home_f8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Home_e2" name="Abrir -&gt; Artista">
      <bpmn:incoming>Home_f9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Home_e3" name="Reproducir -&gt; Now Playing">
      <bpmn:incoming>Home_f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Home_f1" sourceRef="Home_s" targetRef="Home_t1" />
    <bpmn:sequenceFlow id="Home_f2" sourceRef="Home_t1" targetRef="Home_g0" />
    <bpmn:sequenceFlow id="Home_f3" name="No" sourceRef="Home_g0" targetRef="Home_e0" />
    <bpmn:sequenceFlow id="Home_f4" name="Si" sourceRef="Home_g0" targetRef="Home_t2" />
    <bpmn:sequenceFlow id="Home_f5" sourceRef="Home_t2" targetRef="Home_g" />
    <bpmn:sequenceFlow id="Home_f6" name="Guardar / Cola" sourceRef="Home_g" targetRef="Home_t3" />
    <bpmn:sequenceFlow id="Home_f7" sourceRef="Home_t3" targetRef="Home_t2" />
    <bpmn:sequenceFlow id="Home_f8" name="Ver todo" sourceRef="Home_g" targetRef="Home_e1" />
    <bpmn:sequenceFlow id="Home_f9" name="Artista" sourceRef="Home_g" targetRef="Home_e2" />
    <bpmn:sequenceFlow id="Home_f10" name="Reproducir" sourceRef="Home_g" targetRef="Home_e3" />
  </bpmn:process>
  <bpmn:process id="Proc_Library" name="Biblioteca" isExecutable="false">
    <bpmn:startEvent id="Library_s" name="Abrir Biblioteca">
      <bpmn:outgoing>Library_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Library_t1" name="Cargar Catalogo / Mi biblioteca">
      <bpmn:incoming>Library_f1</bpmn:incoming>
      <bpmn:outgoing>Library_f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Library_t2" name="Mostrar lista (canciones, albumes, artistas)">
      <bpmn:incoming>Library_f2</bpmn:incoming>
      <bpmn:incoming>Library_f5</bpmn:incoming>
      <bpmn:incoming>Library_f7</bpmn:incoming>
      <bpmn:incoming>Library_f9</bpmn:incoming>
      <bpmn:outgoing>Library_f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Library_g" name="Accion?">
      <bpmn:incoming>Library_f3</bpmn:incoming>
      <bpmn:outgoing>Library_f4</bpmn:outgoing>
      <bpmn:outgoing>Library_f6</bpmn:outgoing>
      <bpmn:outgoing>Library_f8</bpmn:outgoing>
      <bpmn:outgoing>Library_f10</bpmn:outgoing>
      <bpmn:outgoing>Library_f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Library_b1" name="Buscar / filtrar genero / cambiar scope">
      <bpmn:incoming>Library_f4</bpmn:incoming>
      <bpmn:outgoing>Library_f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Library_imp" name="Importar (modal): subir pista">
      <bpmn:incoming>Library_f6</bpmn:incoming>
      <bpmn:outgoing>Library_f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Library_add" name="Guardar / a cola / a playlist">
      <bpmn:incoming>Library_f8</bpmn:incoming>
      <bpmn:outgoing>Library_f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Library_e1" name="Reproducir -&gt; Now Playing">
      <bpmn:incoming>Library_f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Library_e2" name="Ir a Artista">
      <bpmn:incoming>Library_f11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Library_f1" sourceRef="Library_s" targetRef="Library_t1" />
    <bpmn:sequenceFlow id="Library_f2" sourceRef="Library_t1" targetRef="Library_t2" />
    <bpmn:sequenceFlow id="Library_f3" sourceRef="Library_t2" targetRef="Library_g" />
    <bpmn:sequenceFlow id="Library_f4" name="Buscar / Filtrar" sourceRef="Library_g" targetRef="Library_b1" />
    <bpmn:sequenceFlow id="Library_f5" sourceRef="Library_b1" targetRef="Library_t2" />
    <bpmn:sequenceFlow id="Library_f6" name="Importar" sourceRef="Library_g" targetRef="Library_imp" />
    <bpmn:sequenceFlow id="Library_f7" sourceRef="Library_imp" targetRef="Library_t2" />
    <bpmn:sequenceFlow id="Library_f8" name="Guardar / Cola / Playlist" sourceRef="Library_g" targetRef="Library_add" />
    <bpmn:sequenceFlow id="Library_f9" sourceRef="Library_add" targetRef="Library_t2" />
    <bpmn:sequenceFlow id="Library_f10" name="Reproducir" sourceRef="Library_g" targetRef="Library_e1" />
    <bpmn:sequenceFlow id="Library_f11" name="Artista" sourceRef="Library_g" targetRef="Library_e2" />
  </bpmn:process>
  <bpmn:process id="Proc_Artist" name="Artista" isExecutable="false">
    <bpmn:startEvent id="Artist_s" name="Abrir Artista">
      <bpmn:outgoing>Artist_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Artist_t1" name="Cargar tracks del artista">
      <bpmn:incoming>Artist_f1</bpmn:incoming>
      <bpmn:outgoing>Artist_f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Artist_g0" name="Tiene canciones?">
      <bpmn:incoming>Artist_f2</bpmn:incoming>
      <bpmn:outgoing>Artist_f3</bpmn:outgoing>
      <bpmn:outgoing>Artist_f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Artist_e0" name="Estado vacio">
      <bpmn:incoming>Artist_f3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Artist_t2" name="Mostrar artista (hero + lista)">
      <bpmn:incoming>Artist_f4</bpmn:incoming>
      <bpmn:incoming>Artist_f7</bpmn:incoming>
      <bpmn:outgoing>Artist_f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Artist_g" name="Accion?">
      <bpmn:incoming>Artist_f5</bpmn:incoming>
      <bpmn:outgoing>Artist_f6</bpmn:outgoing>
      <bpmn:outgoing>Artist_f8</bpmn:outgoing>
      <bpmn:outgoing>Artist_f9</bpmn:outgoing>
      <bpmn:outgoing>Artist_f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Artist_t3" name="Guardar (favorito)">
      <bpmn:incoming>Artist_f6</bpmn:incoming>
      <bpmn:outgoing>Artist_f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Artist_e1" name="Reproducir -&gt; Now Playing">
      <bpmn:incoming>Artist_f8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Artist_e2" name="Editar EQ (drawer) -&gt; Ecualizador">
      <bpmn:incoming>Artist_f9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Artist_e3" name="IA sugiere (Premium) -&gt; AI Mixer">
      <bpmn:incoming>Artist_f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Artist_f1" sourceRef="Artist_s" targetRef="Artist_t1" />
    <bpmn:sequenceFlow id="Artist_f2" sourceRef="Artist_t1" targetRef="Artist_g0" />
    <bpmn:sequenceFlow id="Artist_f3" name="No" sourceRef="Artist_g0" targetRef="Artist_e0" />
    <bpmn:sequenceFlow id="Artist_f4" name="Si" sourceRef="Artist_g0" targetRef="Artist_t2" />
    <bpmn:sequenceFlow id="Artist_f5" sourceRef="Artist_t2" targetRef="Artist_g" />
    <bpmn:sequenceFlow id="Artist_f6" name="Guardar" sourceRef="Artist_g" targetRef="Artist_t3" />
    <bpmn:sequenceFlow id="Artist_f7" sourceRef="Artist_t3" targetRef="Artist_t2" />
    <bpmn:sequenceFlow id="Artist_f8" name="Reproducir" sourceRef="Artist_g" targetRef="Artist_e1" />
    <bpmn:sequenceFlow id="Artist_f9" name="EQ" sourceRef="Artist_g" targetRef="Artist_e2" />
    <bpmn:sequenceFlow id="Artist_f10" name="IA" sourceRef="Artist_g" targetRef="Artist_e3" />
  </bpmn:process>
  <bpmn:process id="Proc_Playlists" name="Playlists" isExecutable="false">
    <bpmn:startEvent id="Playlists_s" name="Abrir Playlists">
      <bpmn:outgoing>Playlists_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Playlists_t1" name="Cargar playlists + Me gustan">
      <bpmn:incoming>Playlists_f1</bpmn:incoming>
      <bpmn:outgoing>Playlists_f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Playlists_t2" name="Mostrar grid de playlists">
      <bpmn:incoming>Playlists_f2</bpmn:incoming>
      <bpmn:incoming>Playlists_f5</bpmn:incoming>
      <bpmn:incoming>Playlists_f7</bpmn:incoming>
      <bpmn:incoming>Playlists_f9</bpmn:incoming>
      <bpmn:outgoing>Playlists_f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Playlists_g" name="Accion?">
      <bpmn:incoming>Playlists_f3</bpmn:incoming>
      <bpmn:outgoing>Playlists_f4</bpmn:outgoing>
      <bpmn:outgoing>Playlists_f6</bpmn:outgoing>
      <bpmn:outgoing>Playlists_f8</bpmn:outgoing>
      <bpmn:outgoing>Playlists_f10</bpmn:outgoing>
      <bpmn:outgoing>Playlists_f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Playlists_c" name="Crear playlist (modal)">
      <bpmn:incoming>Playlists_f4</bpmn:incoming>
      <bpmn:outgoing>Playlists_f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Playlists_ec" name="Editar EQ de playlist (modal)">
      <bpmn:incoming>Playlists_f6</bpmn:incoming>
      <bpmn:outgoing>Playlists_f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Playlists_d" name="Eliminar playlist (confirmar)">
      <bpmn:incoming>Playlists_f8</bpmn:incoming>
      <bpmn:outgoing>Playlists_f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Playlists_e1" name="Abrir -&gt; Detalle de playlist">
      <bpmn:incoming>Playlists_f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Playlists_e2" name="Me gustan -&gt; Biblioteca">
      <bpmn:incoming>Playlists_f11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Playlists_f1" sourceRef="Playlists_s" targetRef="Playlists_t1" />
    <bpmn:sequenceFlow id="Playlists_f2" sourceRef="Playlists_t1" targetRef="Playlists_t2" />
    <bpmn:sequenceFlow id="Playlists_f3" sourceRef="Playlists_t2" targetRef="Playlists_g" />
    <bpmn:sequenceFlow id="Playlists_f4" name="Crear" sourceRef="Playlists_g" targetRef="Playlists_c" />
    <bpmn:sequenceFlow id="Playlists_f5" sourceRef="Playlists_c" targetRef="Playlists_t2" />
    <bpmn:sequenceFlow id="Playlists_f6" name="EQ playlist" sourceRef="Playlists_g" targetRef="Playlists_ec" />
    <bpmn:sequenceFlow id="Playlists_f7" sourceRef="Playlists_ec" targetRef="Playlists_t2" />
    <bpmn:sequenceFlow id="Playlists_f8" name="Eliminar" sourceRef="Playlists_g" targetRef="Playlists_d" />
    <bpmn:sequenceFlow id="Playlists_f9" sourceRef="Playlists_d" targetRef="Playlists_t2" />
    <bpmn:sequenceFlow id="Playlists_f10" name="Abrir" sourceRef="Playlists_g" targetRef="Playlists_e1" />
    <bpmn:sequenceFlow id="Playlists_f11" name="Me gustan" sourceRef="Playlists_g" targetRef="Playlists_e2" />
  </bpmn:process>
  <bpmn:process id="Proc_PlaylistDetail" name="Detalle de playlist" isExecutable="false">
    <bpmn:startEvent id="PlaylistDetail_s" name="Abrir Detalle de playlist">
      <bpmn:outgoing>PlaylistDetail_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="PlaylistDetail_t1" name="Cargar playlist y tracks">
      <bpmn:incoming>PlaylistDetail_f1</bpmn:incoming>
      <bpmn:outgoing>PlaylistDetail_f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="PlaylistDetail_g0" name="Tiene tracks?">
      <bpmn:incoming>PlaylistDetail_f2</bpmn:incoming>
      <bpmn:outgoing>PlaylistDetail_f3</bpmn:outgoing>
      <bpmn:outgoing>PlaylistDetail_f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="PlaylistDetail_e0" name="Vacio -&gt; Biblioteca">
      <bpmn:incoming>PlaylistDetail_f3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="PlaylistDetail_t2" name="Mostrar detalle (hero + lista)">
      <bpmn:incoming>PlaylistDetail_f4</bpmn:incoming>
      <bpmn:incoming>PlaylistDetail_f7</bpmn:incoming>
      <bpmn:outgoing>PlaylistDetail_f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="PlaylistDetail_g" name="Accion?">
      <bpmn:incoming>PlaylistDetail_f5</bpmn:incoming>
      <bpmn:outgoing>PlaylistDetail_f6</bpmn:outgoing>
      <bpmn:outgoing>PlaylistDetail_f8</bpmn:outgoing>
      <bpmn:outgoing>PlaylistDetail_f9</bpmn:outgoing>
      <bpmn:outgoing>PlaylistDetail_f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="PlaylistDetail_t3" name="Reordenar / eliminar track">
      <bpmn:incoming>PlaylistDetail_f6</bpmn:incoming>
      <bpmn:outgoing>PlaylistDetail_f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="PlaylistDetail_e1" name="Reproducir -&gt; Now Playing">
      <bpmn:incoming>PlaylistDetail_f8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="PlaylistDetail_e2" name="EQ playlist (Premium) -&gt; Ecualizador">
      <bpmn:incoming>PlaylistDetail_f9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="PlaylistDetail_e3" name="IA sugiere (Premium) -&gt; AI Mixer">
      <bpmn:incoming>PlaylistDetail_f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="PlaylistDetail_f1" sourceRef="PlaylistDetail_s" targetRef="PlaylistDetail_t1" />
    <bpmn:sequenceFlow id="PlaylistDetail_f2" sourceRef="PlaylistDetail_t1" targetRef="PlaylistDetail_g0" />
    <bpmn:sequenceFlow id="PlaylistDetail_f3" name="No" sourceRef="PlaylistDetail_g0" targetRef="PlaylistDetail_e0" />
    <bpmn:sequenceFlow id="PlaylistDetail_f4" name="Si" sourceRef="PlaylistDetail_g0" targetRef="PlaylistDetail_t2" />
    <bpmn:sequenceFlow id="PlaylistDetail_f5" sourceRef="PlaylistDetail_t2" targetRef="PlaylistDetail_g" />
    <bpmn:sequenceFlow id="PlaylistDetail_f6" name="Editar tracks" sourceRef="PlaylistDetail_g" targetRef="PlaylistDetail_t3" />
    <bpmn:sequenceFlow id="PlaylistDetail_f7" sourceRef="PlaylistDetail_t3" targetRef="PlaylistDetail_t2" />
    <bpmn:sequenceFlow id="PlaylistDetail_f8" name="Reproducir" sourceRef="PlaylistDetail_g" targetRef="PlaylistDetail_e1" />
    <bpmn:sequenceFlow id="PlaylistDetail_f9" name="EQ" sourceRef="PlaylistDetail_g" targetRef="PlaylistDetail_e2" />
    <bpmn:sequenceFlow id="PlaylistDetail_f10" name="IA" sourceRef="PlaylistDetail_g" targetRef="PlaylistDetail_e3" />
  </bpmn:process>
  <bpmn:process id="Proc_NowPlaying" name="Now Playing" isExecutable="false">
    <bpmn:startEvent id="NowPlaying_s" name="Abrir Now Playing">
      <bpmn:outgoing>NowPlaying_f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="NowPlaying_g0" name="Hay pista en reproduccion?">
      <bpmn:incoming>NowPlaying_f1</bpmn:incoming>
      <bpmn:outgoing>NowPlaying_f2</bpmn:outgoing>
      <bpmn:outgoing>NowPlaying_f3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="NowPlaying_e0" name="Vacio -&gt; Biblioteca">
      <bpmn:incoming>NowPlaying_f2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="NowPlaying_t1" name="Mostrar reproductor expandido (caratula, onda)">
      <bpmn:incoming>NowPlaying_f3</bpmn:incoming>
      <bpmn:incoming>NowPlaying_f6</bpmn:incoming>
      <bpmn:incoming>NowPlaying_f8</bpmn:incoming>
      <bpmn:outgoing>NowPlaying_f4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="NowPlaying_g" name="Accion?">
      <bpmn:incoming>NowPlaying_f4</bpmn:incoming>
      <bpmn:outgoing>NowPlaying_f5</bpmn:outgoing>
      <bpmn:outgoing>NowPlaying_f7</bpmn:outgoing>
      <bpmn:outgoing>NowPlaying_f9</bpmn:outgoing>
      <bpmn:outgoing>NowPlaying_f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="NowPlaying_t2" name="Play / Pause / Seek (EQ por segmento)">
      <bpmn:incoming>NowPlaying_f5</bpmn:incoming>
      <bpmn:outgoing>NowPlaying_f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="NowPlaying_t3" name="Ver / editar cola">
      <bpmn:incoming>NowPlaying_f7</bpmn:incoming>
      <bpmn:outgoing>NowPlaying_f8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="NowPlaying_e1" name="Abrir Ecualizador">
      <bpmn:incoming>NowPlaying_f9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="NowPlaying_e2" name="Pedir IA -&gt; AI Mixer">
      <bpmn:incoming>NowPlaying_f10</bpmn:incoming>
    </bpmn:endEvent>
